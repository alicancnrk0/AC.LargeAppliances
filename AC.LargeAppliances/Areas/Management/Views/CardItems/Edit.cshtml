@model CardItem

@{
    ViewData["Title"] = "Kart Öğesi Düzenle";
}

<div class="row mb-6 gy-6">
    <div class="col-xl">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Kart Öğesi Düzenle</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @Html.HiddenFor(x => x.Id)
                    @Html.HiddenFor(x => x.IconImagePath)

                    <div class="mb-6">
                        <label asp-for="SortOrder" class="form-label"></label>
                        <input asp-for="SortOrder" class="form-control" type="number" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                    </div>


                    <div class="mb-3">
                        <img src="@Model.IconImagePath" width="80" />
                    </div>
                    
                    <div class="mb-6">
                        <label class="form-label">İkon Görseli</label>
                        <input type="file" name="img" class="form-control" accept="image/*" />
                    </div>

                    <div class="mb-6">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" type="text" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-6">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" type="text" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-6">
                        <button class="btn btn-secondary" asp-action="Index">Geri</button>
                        <button class="btn btn-success" style="float:right" type="submit">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>