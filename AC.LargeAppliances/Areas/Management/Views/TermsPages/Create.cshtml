@model Term

@{
    ViewData["Title"] = "Kullanım Koşulları Sayfası Oluştur";
}

<div class="row mb-6 gy-6">
    <div class="col-xl">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Kullanım Koşulları Sayfası Oluştur</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-6">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" type="text" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-6">
                        <label asp-for="Policy" class="form-label"></label>
                        <textarea asp-for="Policy" class="form-control" style="height:200px; resize:none;"></textarea>
                        <span asp-validation-for="Policy" class="text-danger"></span>
                    </div>

                    <div class="mb-6">
                        <label class="form-label">Görsel</label>
                        <input type="file" name="img" class="form-control" accept="image/*" />
                    </div>

                    <div class="mb-6">
                        <button class="btn btn-secondary" asp-action="Index">Geri</button>
                        <button class="btn btn-success" style="float:right" type="submit">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>