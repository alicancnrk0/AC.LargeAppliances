@model Term

@{
    ViewData["Title"] = "Kullanım Koşulları Sayfası";
}

<div class="row mb-6 gy-6">
    <div class="col-xl">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Kullanım Koşulları Sayfası</h5>
                @if (Model is null)
                {
                    <a class="btn btn-primary" asp-action="Create">Sayfa Oluştur</a>
                }
            </div>
            <div class="card-body">

                <div class="mb-6">
                    <label class="form-label" asp-for="Title"></label>
                    <input type="text" class="form-control" asp-for="Title" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="Policy"></label>
                    <textarea class="form-control" asp-for="Policy" readonly disabled style="height:200px; resize:none;"></textarea>
                </div>

                <div class="mb-6">
                    <label class="form-label">Görsel</label>
                    <img src="@Model?.Img" style="width:80px; height:50px; object-fit:contain; display:block;" />
                </div>

                @if (Model != null)
                {
                    <a class="btn btn-primary" asp-action="Edit">Düzenle</a>
                }
            </div>
        </div>
    </div>
</div>