@model Vendor

@{
    ViewData["Title"] = "Vendor Detay";
}

<div class="row mb-6 gy-6">
    <div class="col-xl">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Vendor Detay</h5>
                <a class="btn btn-secondary" asp-action="Index">Geri</a>
            </div>
            <div class="card-body">

                <div class="mb-6">
                    <label class="form-label" asp-for="Img">Görsel</label>
                    <img src="@Model.Img" style="width:80px; height:50px; object-fit:contain; display:block;" />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="Name"></label>
                    <input type="text" class="form-control" asp-for="Name" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="ReviewCount"></label>
                    <input type="text" class="form-control" asp-for="ReviewCount" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="YearOfFoundation"></label>
                    <input type="text" class="form-control" asp-for="YearOfFoundation" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="ProductTitle"></label>
                    <input type="text" class="form-control" asp-for="ProductTitle" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="ProductCount"></label>
                    <input type="text" class="form-control" asp-for="ProductCount" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="MapIconClass"></label>
                    <input type="text" class="form-control" asp-for="MapIconClass" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="MapAddress"></label>
                    <input type="text" class="form-control" asp-for="MapAddress" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="PhoneIconClass"></label>
                    <input type="text" class="form-control" asp-for="PhoneIconClass" readonly disabled />
                </div>

                <div class="mb-6">
                    <label class="form-label" asp-for="PhoneNumber"></label>
                    <input type="text" class="form-control" asp-for="PhoneNumber" readonly disabled />
                </div>

                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Düzenle</a>
            </div>
        </div>
    </div>
</div>