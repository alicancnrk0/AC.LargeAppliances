<!DOCTYPE html>

<html lang="en"
      class="layout-menu-fixed layout-compact"
      data-assets-path="@Url.Content("~/admin/assets/")"
      data-template="vertical-menu-template-free">
<head>
    @await Html.PartialAsync("Partials/_HeadPartial")
    @await Html.PartialAsync("Partials/_StylesPartial")

    @await RenderSectionAsync("HeadStyles", required: false)
    @await RenderSectionAsync("HeadScripts", required: false)


    @RenderSection("Head", required: false)
    @RenderSection("Styles", required: false)
    @RenderSection("ScriptsHead", required: false)
    @RenderSection("Scripts", required: false)
</head>
<body>
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">
            @await Html.PartialAsync("Sections/_MenuPartial")
            <div class="layout-page">
                @await Html.PartialAsync("Sections/_NavPartial")
                <div class="content-wrapper">
                    <div class="container-xxl flex-grow-1 container-p-y">
                        @RenderBody()
                    </div>
                    @await Html.PartialAsync("Sections/_FooterPartial")

                    <div class="content-backdrop fade"></div>
                </div>
            </div>
        </div>

        <div class="layout-overlay layout-menu-toggle"></div>
    </div>
    @await Html.PartialAsync("Partials/_ScriptsPartial")
    @await RenderSectionAsync("PageScripts", required: false)

    <script async defer src="https://buttons.github.io/buttons.js"></script>
</body>
</html>
