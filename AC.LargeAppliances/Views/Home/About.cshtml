@model AboutPageVM

@{
    ViewData["Title"] = "Hakkımızda";
}


<section class="section-box shop-template mt-30">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <h5 class="color-gray-500 mb-10">@Model.AboutPage?.SubTitle</h5>
                <h2>@Model.AboutPage?.Title</h2>
                <div class="row mt-20">
                    <div class="col-lg-6">
                        <p class="font-sm font-medium color-gray-700 mb-15">@Model.AboutPage?.Description</p>

                        <ul class="list-services mt-20">
                            <li class="@(Model.AboutPage?.Value1IconClass)">@Model.AboutPage?.Value1Title</li>
                            <li class="@(Model.AboutPage?.Value2IconClass)">@Model.AboutPage?.Value2Title</li>
                            <li class="@(Model.AboutPage?.Value3IconClass)">@Model.AboutPage?.Value3Title</li>
                            <li class="@(Model.AboutPage?.Value4IconClass)">@Model.AboutPage?.Value4Title</li>
                        </ul>
                    </div>
                    <div class="col-lg-6"><img src="@(Model.AboutPage?.ImageUrl)" alt="@Model.AboutPage?.Title"></div>
                </div>
                <div class="box-contact-support pt-80 pb-50 pl-50 pr-50 background-gray-50 mt-50 mb-90">
                    <div class="row">
                        <div class="col-lg-3 mb-30 text-center text-lg-start">
                            <h4 class="mb-5">@Model.AboutPage?.Features1Title</h4>
                            <p class="font-md color-gray-700">@Model.AboutPage?.Features1Description</p>
                        </div>
                        <div class="col-lg-3 mb-30 text-center text-lg-start">
                            <h4 class="mb-5">@Model.AboutPage?.Features2Title</h4>
                            <p class="font-md color-gray-700 mb-5">@Model.AboutPage?.Features2Description</p>
                        </div>
                        <div class="col-lg-3 mb-30 text-center text-lg-start">
                            <h4 class="mb-5">@Model.AboutPage?.Features3Title</h4>
                            <p class="font-md color-gray-700 mb-5">@Model.AboutPage?.Features3Description</p>
                        </div>
                        <div class="col-lg-3 mb-30 text-center text-lg-start">
                            <h4 class="mb-5">@Model.AboutPage?.Features4Title</h4>
                            <p class="font-md color-gray-700 mb-5">@Model.AboutPage?.Features4Description</p>
                        </div>
                    </div>
                </div>


                <h5 class="color-gray-500 mb-10">@Model.AboutPage?.PartnerTitle</h5>
                <h2 class="mb-40">@Model.AboutPage?.PartnerDescription</h2>
                <div class="box-images-logo">
                    @foreach (var item in Model.Sponsors.Take(10))
                    {
                        <a class="hover-up">
                            <img src="@item.ImageUrl" alt="@item.Tittle">
                        </a>
                    }
                </div>
                <div class="border-1 mb-80 mt-50"></div>
                <h2 class="mb-5">@Model.AboutPage?.StoresTitle</h2>
                <p class="font-sm color-gray-700">@Model.AboutPage?.StoresDescription</p>
                <div class="box-contact-address pt-30 pb-50">
                    <div class="row">

                        @{
                            var stores = Model.Stores.ToList();
                            int colSize = (int)Math.Ceiling(stores.Count / 3.0);
                            var chunks = stores.Chunk(colSize > 0 ? colSize : 1).ToList();
                        }

                        @foreach (var chunk in chunks)
                        {
                            <div class="col-lg-4">
                                @foreach (var store in chunk)
                                {
                                    <div class="mb-30">
                                        <h4>@store.Title</h4>
                                        <p class="font-sm color-gray-700">@store.Address</p>
                                    </div>
                                }
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>

</section>
<section class="section-box mt-90 mb-50">
    <div class="container">
        <ul class="list-col-5">

            @foreach (var item in Model.CardItems)
            {
                <li>
                    <div class="item-list">
                        <div class="icon-left"><img src="@(item.IconImagePath)" alt="@item.Title"></div>
                        <div class="info-right">
                            <h5 class="font-lg-bold color-gray-100">@item.Title</h5>
                            <p class="font-sm color-gray-500">@item.Description</p>
                        </div>
                    </div>
                </li>
            }

        </ul>
    </div>
</section>
<section class="section-box box-newsletter">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-7 col-sm-12">
                <h3 class="color-white">@Model.Discount?.Title <span class="color-warning">@Model.Discount?.DiscountCount</span> @Model.Discount?.TitleSpan</h3>
                <p class="font-lg color-white">@Model.Discount?.Description</p>
            </div>
            <div class="col-lg-4 col-md-5 col-sm-12">
                <div class="box-form-newsletter mt-15">
                    <form asp-controller="Home" asp-action="Subscribe" method="post">
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                        @Html.AntiForgeryToken()
                        <input class="input-newsletter font-xs" name="mailAddress" placeholder="E-posta adresiniz">
                        <button class="btn btn-brand-2" type="submit">@Model.Discount?.SignButton</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>